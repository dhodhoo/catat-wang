  {
    "id": "TC001",
    "title": "Sign in to access the dashboard",
    "description": "Verifies an existing user can sign in with email and password and is taken to the dashboard successfully.",
    "category": "Authentication (Email/Password Sign‑in)",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /sign-in"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_USER}} into the email field"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_PASSWORD}} into the password field"
      },
      {
        "type": "action",
        "description": "Submit the sign-in form"
      },
      {
        "type": "assertion",
        "description": "Verify the user lands on the dashboard"
      }
    ],
    "priority": "High"
  },
  {
    "id": "TC002",
    "title": "Dashboard updates after creating a new transaction",
    "description": "Verifies that after creating a transaction, the dashboard reflects the change by showing the new item in recent transactions.",
    "category": "Dashboard Analytics",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /sign-in"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_USER}} into the email field"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_PASSWORD}} into the password field"
      },
      {
        "type": "action",
        "description": "Submit the sign-in form"
      },
      {
        "type": "action",
        "description": "Click the navigation link to view transactions"
      },
      {
        "type": "action",
        "description": "Start adding a new transaction"
      },
      {
        "type": "action",
        "description": "Fill 99000 into the amount field"
      },
      {
        "type": "action",
        "description": "Select income as the transaction type"
      },
      {
        "type": "action",
        "description": "Fill a valid date into the transaction date field"
      },
      {
        "type": "action",
        "description": "Select a category for the transaction"
      },
      {
        "type": "action",
        "description": "Fill DashRefresh TC008 into the note field"
      },
      {
        "type": "action",
        "description": "Submit the new transaction"
      },
      {
        "type": "action",
        "description": "Click the navigation link to view the dashboard"
      },
      {
        "type": "assertion",
        "description": "Verify a recent transaction with note \"DashRefresh TC008\" is displayed on the dashboard"
      }
    ],
    "priority": "High"
  },
